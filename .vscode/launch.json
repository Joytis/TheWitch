            "request": "attach",
            "processName": "SlayTheSpire2.exe",
            "preLaunchTask": "Debug: Publish + Launch into combat",
            "justMyCode": false,
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            }
        },
        {
            // Build + AutoSlay bot on the Witch + attach. Log tails in the task panel.
            "name": "AutoSlay + Attach",
            "type": "coreclr",
            "request": "attach",
            "processName": "SlayTheSpire2.exe",
            "preLaunchTask": "Debug: Build + Launch AutoSlay",
            "justMyCode": false,
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            }
        },
        {
            // Build + FX Lab browser scene + attach. Log tails in the task panel.
            "name": "FX Lab + Attach",
            "type": "coreclr",
            "request": "attach",
            "processName": "SlayTheSpire2.exe",
