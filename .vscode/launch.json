{
    "version": "0.2.0",
    "configurations": [
        {
            // Full publish flow (menu, .pck export) + attach. Log tails in the task panel.
            "name": "Launch STS2 + Attach",
            "type": "coreclr",
            "request": "attach",
            "processName": "SlayTheSpire2.exe",
            "preLaunchTask": "Publish and Run",
            "justMyCode": false,
            "symbolOptions": {
                "searchMicrosoftSymbolServer": false
            }
        },
        {
            // Publish + straight into a Witch combat (100 energy) + attach. Log tails in the task panel.
            "name": "Combat + Attach",
