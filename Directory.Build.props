<Project>
    <!-- Machine-specific settings (GodotPath, Sts2Path, ...) live in local.props — gitignored, optional. -->
    <Import Project="local.props" Condition="Exists('local.props')"/>

    <!--
      local.props example:

      <Project>
          <PropertyGroup>
              <!- MegaDot / Godot mono executable used for export-pack when publishing.
                  Must be 4.5.x - the game won't load a .pck exported by a newer Godot. ->
              <GodotPath>C:/megadot/MegaDot_v4.5.1-stable_mono_win64.exe</GodotPath>

              <!- Set if sts2 is not found automatically (see Sts2PathDiscovery.props) ->
              <Sts2Path>?/steamapps/common/Slay the Spire 2</Sts2Path>
          </PropertyGroup>
      </Project>
    -->
</Project>
